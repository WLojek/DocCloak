{
  "name": "doccloak",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "description": "Offline, open-source document anonymizer. Strip PII before sharing with AI services.",
  "license": "AGPL-3.0",
  "author": "Witold Lojek",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');for(const f of ['ort-wasm-simd-threaded.wasm','ort-wasm-simd-threaded.jsep.wasm'])fs.copyFileSync('node_modules/onnxruntime-web/dist/'+f,'public/'+f)\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "cfb": "1.2.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jszip": "3.10.1",
    "lucide-react": "0.577.0",
    "onnxruntime-web": "1.19.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "jsdom": "24.1.3",
    "tailwindcss": "4.2.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.57.0",
    "vite": "6.4.1",
    "vitest": "4.1.0"
  }
}
